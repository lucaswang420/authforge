    "/oauth2/authorize" : 
    {
      "get" : 
      {
        "description" : "OAuth2 authorization endpoint - initiates authorization flow",
        "operationId" : "get_oauth2_authorize",
        "parameters" : 
        [
          {
            "description" : "Client identifier (required)",
            "in" : "query",
            "name" : "client_id",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Redirect URI (required)",
            "in" : "query",
            "name" : "redirect_uri",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Response type, must be 'code' (required)",
            "in" : "query",
            "name" : "response_type",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Requested scope (optional)",
            "in" : "query",
            "name" : "scope",
            "required" : false,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Opaque value to maintain state between request and callback (recommended)",
            "in" : "query",
            "name" : "state",
            "required" : false,
            "schema" : 
            {
              "type" : "string"
            }
          }
        ],
        "responses" : 
        {
          "302" : 
          {
            "description" : "Redirect to client with authorization code"
          },
          "400" : 
          {
            "description" : "Invalid request"
          }
        },
        "summary" : "Request authorization",
        "tags" : 
        [
          "OAuth2",
          "Authorization"
        ]
      }
    },
    "/oauth2/login" : 
    {
      "post" : 
      {
        "description" : "Authenticates user credentials and generates authorization code",
        "operationId" : "post_oauth2_login",
        "parameters" : 
        [
          {
            "description" : "Username (required)",
            "in" : "query",
            "name" : "username",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Password (required)",
            "in" : "query",
            "name" : "password",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Client identifier (required)",
            "in" : "query",
            "name" : "client_id",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Redirect URI (required)",
            "in" : "query",
            "name" : "redirect_uri",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Requested scope (optional)",
            "in" : "query",
            "name" : "scope",
            "required" : false,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Opaque value to maintain state (recommended)",
            "in" : "query",
            "name" : "state",
            "required" : false,
            "schema" : 
            {
              "type" : "string"
            }
          }
        ],
        "responses" : 
        {
          "200" : 
          {
            "content" : 
            {
              "application/json" : 
              {
                "schema" : 
                {
                  "type" : "object"
                }
              }
            },
            "description" : "Authentication successful"
          },
          "302" : 
          {
            "description" : "Redirect with authorization code"
          },
          "401" : 
          {
            "description" : "Authentication failed"
          }
        },
        "summary" : "Authenticate user",
        "tags" : 
        [
          "OAuth2",
          "Authentication"
        ]
      }
    },
    "/oauth2/token" : 
    {
      "post" : 
      {
        "description" : "OAuth2 token endpoint - exchanges authorization code or refresh token for access token",
        "operationId" : "post_oauth2_token",
        "parameters" : 
        [
          {
            "description" : "Authorization code or refresh token (required)",
            "in" : "query",
            "name" : "grant_type",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Authorization code (required for grant_type=authorization_code)",
            "in" : "query",
            "name" : "code",
            "required" : false,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Refresh token (required for grant_type=refresh_token)",
            "in" : "query",
            "name" : "refresh_token",
            "required" : false,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Client identifier (required)",
            "in" : "query",
            "name" : "client_id",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Client secret (required for confidential clients)",
            "in" : "query",
            "name" : "client_secret",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          },
          {
            "description" : "Redirect URI (required for authorization_code grant)",
            "in" : "query",
            "name" : "redirect_uri",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          }
        ],
        "responses" : 
        {
          "200" : 
          {
            "content" : 
            {
              "application/json" : 
              {
                "schema" : 
                {
                  "type" : "object"
                }
              }
            },
            "description" : "Token response with access_token and refresh_token"
          },
          "400" : 
          {
            "description" : "Invalid request"
          },
          "401" : 
          {
            "description" : "Authentication failed"
          }
        },
        "summary" : "Exchange authorization code for access token",
        "tags" : 
        [
          "OAuth2",
          "Token"
        ]
      }
    },
