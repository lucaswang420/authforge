  "paths" : 
  {
    "/api/google/login" : 
    {
      "post" : 
      {
        "description" : "Exchange Google authorization code for user information. This endpoint handles the server-side OAuth2 flow with Google Identity Platform.",
        "operationId" : "post_api_google_login",
        "parameters" : 
        [
          {
            "description" : "Authorization code from Google OAuth2 callback (required)",
            "in" : "query",
            "name" : "code",
            "required" : true,
            "schema" : 
            {
              "type" : "string"
            }
          }
        ],
        "responses" : 
        {
          "200" : 
          {
            "content" : 
            {
              "application/json" : 
              {
                "example" : 
                {
                  "email" : "john.doe@gmail.com",
                  "name" : "John Doe",
                  "picture" : "https://lh3.googleusercontent.com/...",
                  "sub" : "123456789012345678901"
                }
              }
            },
            "description" : "Google user info retrieved successfully"
          },
          "400" : 
          {
            "content" : 
            {
              "application/json" : 
              {
                "example" : 
                {
                  "error" : "Missing code parameter"
                }
              }
            },
            "description" : "Invalid request (missing or invalid code)"
          },
          "502" : 
          {
            "description" : "Failed to contact Google API"
          }
        },
        "summary" : "Google OAuth2 Login",
        "tags" : 
        [
          "External Auth",
          "Google"
        ]
      }
    },
