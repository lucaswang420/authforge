{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Debug",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [
                "-c",
                "config.json"
            ],
            "stopAtEntry": false,
            "cwd": "${command:cmake.buildDirectory}/OAuth2Server/${command:cmake.buildType}",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "CMake: Build Debug"
        }
    ]
}
